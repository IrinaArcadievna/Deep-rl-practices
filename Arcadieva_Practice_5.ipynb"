{"cells":[{"cell_type":"markdown","metadata":{"id":"WRdHdOIGr5Te"},"source":["#Домашняя работа 5"]},{"cell_type":"markdown","metadata":{"id":"PS1n-ooesGul"},"source":["Требуется выполнить два задания:\n","\n","1. Обучить Агента решать Acrobot-v1, MountainCar-v0, или LunarLander-v2 (одну на выбор) методом DQN. Найти оптимальные гиперпараметры. Сравнить с алгоритмом Deep Cross-Entropy на графиках.\n","2. Реализовать и сравнить (на выбранной ранее среде) друг с другом и с обычным DQN следующие его модификации:\n"," - DQN с Hard Target Update;\n"," - DQN с Soft Target Update;\n"," - Double DQN."]},{"cell_type":"code","execution_count":null,"metadata":{"executionInfo":{"elapsed":10185,"status":"ok","timestamp":1702042361182,"user":{"displayName":"Irina Arcadieva","userId":"00917846547842133085"},"user_tz":-120},"id":"cWVdTXZyBZkk","colab":{"base_uri":"https://localhost:8080/"},"outputId":"6531d6a7-a2d7-4a5f-a5da-b1fa71c988e2"},"outputs":[{"output_type":"stream","name":"stdout","text":["\u001b[?25l     \u001b[90m━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\u001b[0m \u001b[32m0.0/953.9 kB\u001b[0m \u001b[31m?\u001b[0m eta \u001b[36m-:--:--\u001b[0m\r\u001b[2K     \u001b[91m━\u001b[0m\u001b[90m╺\u001b[0m\u001b[90m━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\u001b[0m \u001b[32m30.7/953.9 kB\u001b[0m \u001b[31m788.9 kB/s\u001b[0m eta \u001b[36m0:00:02\u001b[0m\r\u001b[2K     \u001b[91m━━\u001b[0m\u001b[91m╸\u001b[0m\u001b[90m━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\u001b[0m \u001b[32m61.4/953.9 kB\u001b[0m \u001b[31m796.0 kB/s\u001b[0m eta \u001b[36m0:00:02\u001b[0m\r\u001b[2K     \u001b[91m━━━━━━━\u001b[0m\u001b[90m╺\u001b[0m\u001b[90m━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\u001b[0m \u001b[32m174.1/953.9 kB\u001b[0m \u001b[31m1.6 MB/s\u001b[0m eta \u001b[36m0:00:01\u001b[0m\r\u001b[2K     \u001b[91m━━━━━━━━━━━━━━━━\u001b[0m\u001b[91m╸\u001b[0m\u001b[90m━━━━━━━━━━━━━━━━━━━━━━━\u001b[0m \u001b[32m399.4/953.9 kB\u001b[0m \u001b[31m2.7 MB/s\u001b[0m eta \u001b[36m0:00:01\u001b[0m\r\u001b[2K     \u001b[91m━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\u001b[0m\u001b[90m╺\u001b[0m\u001b[90m━━━━━━\u001b[0m \u001b[32m788.5/953.9 kB\u001b[0m \u001b[31m4.4 MB/s\u001b[0m eta \u001b[36m0:00:01\u001b[0m\r\u001b[2K     \u001b[90m━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\u001b[0m \u001b[32m953.9/953.9 kB\u001b[0m \u001b[31m4.6 MB/s\u001b[0m eta \u001b[36m0:00:00\u001b[0m\n","\u001b[?25h"]}],"source":["!pip install -q gymnasium"]},{"cell_type":"code","execution_count":null,"metadata":{"id":"rOYXnZQg0bCU"},"outputs":[],"source":["import gymnasium as gym\n","\n","import numpy as np\n","import random\n","import torch\n","import torch.nn as nn\n","import time\n","\n","import matplotlib.pyplot as plt\n","%matplotlib inline"]},{"cell_type":"markdown","metadata":{"id":"YYk7Ciyl1LkH"},"source":["## Задание 1\n","Обучить Агента решать Acrobot-v1, MountainCar-v0, или LunarLander-v2 (одну на выбор) методом DQN. Найти оптимальные гиперпараметры. Сравнить с алгоритмом Deep Cross-Entropy на графиках.\n"]},{"cell_type":"markdown","metadata":{"id":"yGPcesXvp9f7"},"source":["### Deep Q Net Method\n","\n","Задаем структуру аппроксимации $Q^\\theta$, начальные вектор параметров $\\theta$, вероятность исследования среды $\\varepsilon = 1$.\n","\n","Для каждого эпизода $k$ делаем:\n","\n","Пока эпизод не закончен делаем:\n","\n","- Находясь в состоянии $S_t$ совершаем действие $A_t \\sim \\pi(\\cdot|S_t)$, где $\\pi = \\varepsilon\\text{-greedy}(Q^\\theta)$, получаем награду $R_t$  переходим в состояние $S_{t+1}$. Сохраняем $(S_t,A_t,R_t,S_{t+1}) \\rightarrow Memory$\n","\n","\n","- Берем $\\{(s_i,a_i,r_i,s'_i)\\}_{i=1}^{n} \\leftarrow Memory$, определяем целевые значения\n","\n","$$\n","y_i =\n","\\left\\{\n","\\begin{array}{ll}\n","r_i, &\\text{ если } s'_i\\text{ -терминальное},\\\\[0.0cm]\n"," r_i + \\gamma \\max\\limits_{a'} Q^\\theta(s'_i,a'), &\\text{ иначе}\n","\\end{array}\n","\\right.\n","$$\n","\n","функцию потерь $Loss(\\theta) = \\frac{1}{n}\\sum\\limits_{i=1}^n \\big(y_i - Q^\\theta(s_i,a_i)\\big)^2$\n","и обновляем вектор параметров\n","\n","$$\n","\\theta \\leftarrow \\theta - \\alpha \\nabla_\\theta Loss(\\theta)\n","$$\n","\n","- Уменьшаем $\\varepsilon$\n"]},{"cell_type":"code","execution_count":null,"metadata":{"id":"EEjFGbztp9gT"},"outputs":[],"source":["class Qfunction(nn.Module):\n","    def __init__(self, state_dim, action_dim):\n","        super().__init__()\n","        self.linear_1 = nn.Linear(state_dim, 128)\n","        self.linear_2 = nn.Linear(128, action_dim)\n","        self.activation = nn.ReLU()\n","\n","    def forward(self, states):\n","        hidden = self.linear_1(states)\n","        hidden = self.activation(hidden)\n","        actions = self.linear_2(hidden)\n","        return actions"]},{"cell_type":"code","execution_count":null,"metadata":{"id":"y3WMLOVMp9gc"},"outputs":[],"source":["class DQN:\n","    def __init__(self, state_dim, action_dim, gamma=0.99, lr=1e-3,\n","                 batch_size=64, epsilon_decrease=0.01, epilon_min=0.01):\n","        self.state_dim = state_dim\n","        self.action_dim = action_dim\n","        self.q_function = Qfunction(self.state_dim, self.action_dim)\n","        self.gamma = gamma\n","        self.batch_size = batch_size\n","        self.epsilon = 1\n","        self.epsilon_decrease = epsilon_decrease\n","        self.epilon_min = epilon_min\n","        self.memory = []\n","        self.optimzaer = torch.optim.Adam(self.q_function.parameters(), lr=lr)\n","\n","    def get_action(self, state):\n","        q_values = self.q_function(torch.FloatTensor(state))\n","        argmax_action = torch.argmax(q_values)\n","        probs = self.epsilon * np.ones(self.action_dim) / self.action_dim\n","        probs[argmax_action] += 1 - self.epsilon\n","        action = np.random.choice(np.arange(self.action_dim), p=probs)\n","        return action\n","\n","    def fit(self, state, action, reward, termin, trunc, next_state):\n","        self.memory.append([state, action, reward,\n","                            int(termin), int(trunc), next_state])\n","\n","        if len(self.memory) > self.batch_size:\n","            batch = random.sample(self.memory, self.batch_size)\n","            states, actions, rewards, termins, truncs, next_states \\\n","                             = map(torch.tensor, list(zip(*batch)))\n","\n","            targets = rewards + self.gamma * (1 - termins) * (1 - truncs) \\\n","                      * torch.max(self.q_function(next_states), dim=1).values\n","            q_values = self.q_function(states)[torch.arange(self.batch_size), actions]\n","\n","            loss = torch.mean((q_values - targets.detach()) ** 2)\n","            loss.backward()\n","            self.optimzaer.step()\n","            self.optimzaer.zero_grad()\n","\n","            if self.epsilon > self.epilon_min:\n","                self.epsilon -= self.epsilon_decrease"]},{"cell_type":"code","execution_count":null,"metadata":{"id":"Ipr7QDKn2hfA"},"outputs":[],"source":["def call_DQN(env, agent, episode_n, t_max):\n","    total_rewards = []\n","    for episode in range(episode_n):\n","        total_reward = 0\n","\n","        state, _ = env.reset()\n","        for t in range(t_max):\n","            action = agent.get_action(state)\n","            next_state, reward, termin, trunc, _ = env.step(action)\n","            total_reward += reward\n","\n","            agent.fit(state, action, reward, termin, trunc, next_state)\n","            state = next_state\n","\n","            if termin or trunc:\n","                break\n","\n","        total_rewards.append(total_reward)\n","    return total_rewards"]},{"cell_type":"markdown","source":["### Deep Cross Entropy Method"],"metadata":{"id":"HcEr12_d5IBm"}},{"cell_type":"code","execution_count":null,"metadata":{"id":"rOHsIYvVp9go"},"outputs":[],"source":["class Acrobot(nn.Module):\n","    def __init__(self, state_dim, action_n, hidden_n):\n","        super().__init__()\n","        self.state_dim = state_dim\n","        self.action_n = action_n\n","        self.hidden_n = hidden_n\n","\n","        self.network = nn.Sequential(\n","            nn.Linear(self.state_dim, hidden_n),\n","            nn.ReLU(),\n","            nn.Linear(hidden_n, self.action_n)\n","        )\n","\n","    def forward(self, input):\n","        return self.network(input)\n"]},{"cell_type":"code","execution_count":null,"metadata":{"id":"gsgGZThX43M2"},"outputs":[],"source":["def cross_entropy(env, agent, optimizer, loss_fun,\n","                  iteration_n, trajectory_n, t_max, q_param):\n","\n","    total_rewards = []\n","\n","    for iteration in range(iteration_n):\n","\n","        #policy evaluation\n","        all_states, all_actions, all_rewards = [], [], []\n","        for k in range(trajectory_n):\n","            states, actions, total_reward = get_trajectory(env, agent, t_max)\n","            all_states.append(states)\n","            all_actions.append(actions)\n","            all_rewards.append(total_reward)\n","        total_rewards.extend(all_rewards)\n","\n","      #  print('iteration:', iteration,\n","      #        'mean total reward:', np.mean(all_rewards))\n","\n","        #policy improvement\n","        elite_states, elite_actions = select_elites(all_states, all_actions,\n","                                                    all_rewards, q_param)\n","        if len(elite_states) > 0:\n","            pred_actions = agent(torch.FloatTensor(elite_states))\n","\n","            loss = loss_fun(pred_actions, torch.LongTensor(elite_actions))\n","            loss.backward()\n","            optimizer.step()\n","            optimizer.zero_grad()\n","\n","    return total_rewards\n"]},{"cell_type":"code","execution_count":null,"metadata":{"id":"_t-5V4Yt5NG3"},"outputs":[],"source":["def get_trajectory(env, agent, max_len=1000):\n","\n","    states, actions = [], []\n","    total_reward = 0.0\n","\n","    state, _ = env.reset()\n","\n","    for _ in range(max_len):\n","\n","        logit = agent(torch.FloatTensor(state))\n","        action_prob = logit.softmax(dim=0).detach().numpy()\n","        action = np.random.choice(action_dim, p=action_prob)\n","\n","        new_state, reward, terminated, truncated, _ = env.step(action)\n","\n","        states.append(state)\n","        actions.append(action)\n","        total_reward += reward\n","\n","        state = new_state\n","        if terminated or truncated:\n","            break\n","\n","    return states, actions, total_reward"]},{"cell_type":"code","execution_count":null,"metadata":{"id":"zebdG9jZ5Nb_"},"outputs":[],"source":["def select_elites(all_states, all_actions, all_rewards, q_param):\n","    quantile = np.quantile(all_rewards, q_param)\n","    elite_states = []\n","    elite_actions = []\n","    for i in range(len(all_rewards)):\n","        if all_rewards[i] > quantile:\n","            elite_states.extend(all_states[i])\n","            elite_actions.extend(all_actions[i])\n","    return elite_states, elite_actions\n"]},{"cell_type":"markdown","source":["### Сравнение методов\n","Для сравнения методов зададим максимально одинаковые параметры, включая структуру сети. Однако полное сравнение произвести не получится, так как количество построенных траекторий и количество обучаемых траекторий определяется методами по разному."],"metadata":{"id":"CGUEcoT0563W"}},{"cell_type":"code","execution_count":null,"metadata":{"id":"UUMFk99yKap1"},"outputs":[],"source":["# ENVIRONMENT\n","\n","env = gym.make(\"Acrobot-v1\", render_mode='rgb_array')\n","state_dim = env.observation_space.shape[0]\n","action_dim = env.action_space.n\n"]},{"cell_type":"code","execution_count":null,"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":507},"executionInfo":{"elapsed":451892,"status":"ok","timestamp":1701452469239,"user":{"displayName":"Irina Arcadieva","userId":"00917846547842133085"},"user_tz":-120},"id":"MhFnuSxd6fvD","outputId":"d065a4f8-6216-4cf3-b23b-d2d2b8829650"},"outputs":[{"output_type":"stream","name":"stdout","text":["Time of method running 7.51 minutes\n","Last mean total reward in Deep Q Net Method =  -91.28\n"]},{"output_type":"display_data","data":{"text/plain":["<Figure size 640x480 with 1 Axes>"],"image/png":"\n"},"metadata":{}}],"source":["# Deep Q Net Method\n","\n","gamma = 0.99\n","lr = 0.01\n","batch_size = 500\n","epsilon_decrease = 0.01\n","epsilon_min = 0.01\n","\n","episode_n = 500\n","t_max = 500\n","\n","agent = DQN(state_dim, action_dim, gamma, lr,\n","            batch_size, epsilon_decrease, epsilon_min)\n","\n","start = time.time()\n","total_rewards = call_DQN(env, agent, episode_n, t_max)\n","print('Time of method running',\n","      np.round((time.time() - start) / 60, 2), 'minutes')\n","\n","mean_total_rewards = [np.mean(total_rewards[iter * episode_n // 20:\n","                                            (iter + 1) * episode_n // 20])\n","                      for iter in range(20)]\n","\n","print('Last mean total reward in Deep Q Net Method = ',\n","      np.round(mean_total_rewards[-1], 2))\n","\n","plt.plot(total_rewards, label='total_rewards')\n","plt.plot(range(0, episode_n, episode_n // 20),\n","         mean_total_rewards, label='mean_total_rewards', color='red')\n","\n","plt.title('Deep Q Net Method')\n","plt.xlabel('Episodes')\n","plt.ylabel('Rewards')\n","plt.legend()\n","plt.show()"]},{"cell_type":"code","execution_count":null,"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":507},"executionInfo":{"elapsed":526146,"status":"ok","timestamp":1701451923130,"user":{"displayName":"Irina Arcadieva","userId":"00917846547842133085"},"user_tz":-120},"id":"457c-NLcAmv6","outputId":"1844506a-a4eb-4c6e-de7c-078d8521c6f3"},"outputs":[{"output_type":"stream","name":"stdout","text":["Time of method running 8.75 minutes\n","Last mean total reward in Deep Cross Entropy Method =  -83.84\n"]},{"output_type":"display_data","data":{"text/plain":["<Figure size 640x480 with 1 Axes>"],"image/png":"\n"},"metadata":{}}],"source":["# Deep Cross Entropy Method\n","\n","iteration_n = 20\n","trajectory_n = 500\n","t_max = 500\n","hidden_n = 128\n","q_param = 0.5\n","learn_rate = 0.01\n","\n","agent = Acrobot(state_dim, action_dim, hidden_n)\n","optimizer = torch.optim.Adam(agent.parameters(), lr=learn_rate)\n","loss_fun = nn.CrossEntropyLoss()\n","\n","start = time.time()\n","total_rewards = cross_entropy(env, agent, optimizer, loss_fun,\n","                              iteration_n, trajectory_n, t_max, q_param)\n","print('Time of method running',\n","      np.round((time.time() - start) / 60, 2), 'minutes')\n","\n","mean_total_rewards = [np.mean(total_rewards[iter * trajectory_n:\n","                                            (iter + 1) * trajectory_n])\n","                      for iter in range(iteration_n)]\n","\n","print('Last mean total reward in Deep Cross Entropy Method = ',\n","      np.round(mean_total_rewards[-1], 2))\n","\n","plt.plot(total_rewards, label='total_rewards')\n","plt.plot(range(0, iteration_n * trajectory_n, trajectory_n),\n","         mean_total_rewards, label='mean_total_rewards', color='red')\n","\n","plt.title('Deep Cross Entropy Method')\n","plt.xlabel('Iterations')\n","plt.ylabel('Rewards')\n","plt.legend()\n","plt.show()\n"]},{"cell_type":"markdown","source":["Выводы:\n","1. Параметры были подобраны так, чтобы время работы методов было соизмеримо между собой.\n","2. Метод DQN практически сразу вышел на нужный диапазон значений наград, однако разброс средних значений в этом диапазоне довольно существенный. Увеличение же количества эпизодов только ухудшает картину, разброс средних значений становится еще больше.\n","3. Метод DCE после выхода на нужный диапазон показывает более стабильные результаты. Итоговое значение общей награды выше."],"metadata":{"id":"TvHDvJdQ1f8K"}},{"cell_type":"markdown","source":["## Задание 2\n","Реализовать и сравнить (на выбранной ранее среде) друг с другом и с обычным DQN следующие его модификации:\n"," - DQN с Hard Target Update;\n"," - DQN с Soft Target Update;\n"," - Double DQN."],"metadata":{"id":"ZgaiL-uAgEil"}},{"cell_type":"markdown","source":["### Modified DQN"],"metadata":{"id":"d-o5Ceua47_o"}},{"cell_type":"code","source":["class Qfun(nn.Module):\n","    def __init__(self, state_dim, action_dim, hidden_dim):\n","        super().__init__()\n","        self.linear_1 = nn.Linear(state_dim, hidden_dim)\n","        self.linear_2 = nn.Linear(hidden_dim, action_dim)\n","        self.activation = nn.ReLU()\n","\n","    def forward(self, states):\n","        hidden = self.linear_1(states)\n","        hidden = self.activation(hidden)\n","        actions = self.linear_2(hidden)\n","        return actions"],"metadata":{"id":"6snwhcsd43y0"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["class Modified_DQN:\n","    def __init__(self, state_dim, action_dim, hidden_dim, gamma=0.99, lr=1e-3,\n","                 batch_size=64, epsilon_decrease=0.01, epilon_min=0.01):\n","        self.state_dim = state_dim\n","        self.action_dim = action_dim\n","        self.hidden_dim = hidden_dim\n","        self.q_fun_cur = Qfun(self.state_dim, self.action_dim, self.hidden_dim)\n","        self.q_fun_new = Qfun(self.state_dim, self.action_dim, self.hidden_dim)\n","        self.gamma = gamma\n","        self.batch_size = batch_size\n","        self.epsilon = 1\n","        self.epsilon_decrease = epsilon_decrease\n","        self.epilon_min = epilon_min\n","        self.memory = []\n","        self.optimazer = torch.optim.Adam(self.q_fun_cur.parameters(), lr=lr)\n","\n","        for param in self.q_fun_new.parameters():\n","            param.requires_grad = False              # not train\n","\n","    def get_action(self, state):\n","        q_values = self.q_fun_cur(torch.FloatTensor(state))\n","        argmax_action = torch.argmax(q_values)\n","        probs = self.epsilon * np.ones(self.action_dim) / self.action_dim\n","        probs[argmax_action] += 1 - self.epsilon\n","        action = np.random.choice(np.arange(self.action_dim), p=probs)\n","        return action\n","\n","    def fit(self, state, action, reward, termin, trunc, next_state, method):\n","        self.memory.append([state, action, reward,\n","                            int(termin), int(trunc), next_state])\n","\n","        if len(self.memory) > self.batch_size:\n","            batch = random.sample(self.memory, self.batch_size)\n","            states, actions, rewards, termins, truncs, next_states \\\n","                             = map(torch.tensor, list(zip(*batch)))\n","            if method == 0:\n","                # DQN Method\n","                targets = rewards + self.gamma * (1 - termins) * (1 - truncs) \\\n","                        * torch.max(self.q_fun_cur(next_states), dim=1).values\n","            elif method == 1 or method == 2:\n","                # Hard or Soft Target\n","                targets = rewards + self.gamma * (1 - termins) * (1 - truncs) \\\n","                        * torch.max(self.q_fun_new(next_states), dim=1).values\n","            elif method == 3:\n","                # Double DQN\n","                targets = rewards + self.gamma * (1 - termins) * (1 - truncs) \\\n","                 * self.q_fun_cur(next_states)[torch.arange(self.batch_size),\n","                        torch.argmax(self.q_fun_new(next_states), dim=1)]\n","            else:\n","                print('Method is not found')\n","\n","            q_values = self.q_fun_cur(states)[torch.arange(self.batch_size), actions]\n","\n","            loss = torch.mean((q_values - targets.detach()) ** 2)\n","            loss.backward()\n","            self.optimazer.step()\n","            self.optimazer.zero_grad()\n","\n","            if self.epsilon > self.epilon_min:\n","                self.epsilon -= self.epsilon_decrease\n","\n","    def mod_dqn(self, env, episode_n, t_max, tau, method):\n","        total_rewards = []\n","        for episode in range(episode_n):\n","            total_reward = 0\n","\n","            if method == 1:\n","                if (episode_n % 50 == 0):\n","                    for new_par, cur_par in zip(self.q_fun_new.parameters(),\n","                                                self.q_fun_cur.parameters()):\n","                        new_par.data.copy_(cur_par.data)\n","\n","            state, _ = env.reset()\n","            for t in range(t_max):\n","\n","                action = self.get_action(state)\n","                next_state, reward, termin, trunc, _ = env.step(action)\n","                total_reward += reward\n","                self.fit(state, action, reward, termin, trunc, next_state, method)\n","                state = next_state\n","\n","                if method == 2 or method == 3:\n","                    for new_par, cur_par in zip(self.q_fun_new.parameters(),\n","                                                self.q_fun_cur.parameters()):\n","                        new_par.data.copy_(tau * cur_par.data + (1 - tau) * new_par.data)\n","                if termin or trunc:\n","                    break\n","\n","            total_rewards.append(total_reward)\n","      #      print(episode, total_reward)\n","        return total_rewards\n"],"metadata":{"id":"EtfEfG2y44UG"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["def view_results(total_rewards, method):\n","\n","    name_of_method = ['DQN Method', 'DQN with Hard Target Update',\n","                      'DQN with Soft Target Update', 'Double DQN']\n","\n","    mean_total_rewards = [np.mean(total_rewards[iter * episode_n // 20:\n","                                                (iter + 1) * episode_n // 20])\n","                          for iter in range(20)]\n","\n","    print()\n","    print('Last mean total reward in', name_of_method[method],\n","          np.round(mean_total_rewards[-1], 2))\n","\n","    plt.plot(total_rewards, label='total_rewards')\n","    plt.plot(range(0, episode_n, episode_n // 20),\n","             mean_total_rewards, label='mean_total_rewards', color='red')\n","    plt.title(name_of_method[method])\n","    plt.xlabel('Episodes')\n","    plt.ylabel('Rewards')\n","    plt.legend()\n","    plt.show()\n"],"metadata":{"id":"s0yUQWmjEyOZ"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["# ENVIRONMENT\n","\n","env = gym.make(\"Acrobot-v1\", render_mode='rgb_array')\n","state_dim = env.observation_space.shape[0]\n","action_dim = env.action_space.n\n","hidden_dim = 128"],"metadata":{"id":"yIfQmW8Nrwia"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["# Modified DQN Methods\n","#     method = 0 means DQN Method\n","#     method = 1 means DQN with Hard Target Update\n","#     method = 2 means DQN with Soft Target Update\n","#     method = 3 means Double DQN\n","\n","gamma = 0.99\n","lr = 0.01\n","batch_size = 500\n","epsilon_decrease = 0.01\n","epsilon_min = 0.01\n","\n","episode_n = 500\n","t_max = 500\n","tau = 0.01\n","\n","for method in [0, 1, 2, 3]:\n","    agent = Modified_DQN(state_dim, action_dim, hidden_dim, gamma, lr,\n","                         batch_size, epsilon_decrease, epsilon_min)\n","\n","    total_rewards = agent.mod_dqn(env, episode_n, t_max, tau, method)\n","\n","    view_results(total_rewards, method)"],"metadata":{"id":"v1Uho8rJL3Mq","colab":{"base_uri":"https://localhost:8080/","height":1000},"executionInfo":{"status":"ok","timestamp":1702048438253,"user_tz":-120,"elapsed":1786594,"user":{"displayName":"Irina Arcadieva","userId":"00917846547842133085"}},"outputId":"fc1f7cd1-be07-4b5b-8214-c5a0952122ba"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["\n","Last mean total reward in DQN Method -186.44\n"]},{"output_type":"display_data","data":{"text/plain":["<Figure size 640x480 with 1 Axes>"],"image/png":"\n"},"metadata":{}},{"output_type":"stream","name":"stdout","text":["\n","Last mean total reward in DQN with Hard Target Update -84.56\n"]},{"output_type":"display_data","data":{"tex