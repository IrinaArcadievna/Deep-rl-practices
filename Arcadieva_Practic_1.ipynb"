{"nbformat":4,"nbformat_minor":0,"metadata":{"colab":{"provenance":[{"file_id":"1l19R_GtYqdulLHj_ww-JnjZ0Lx87Agi1","timestamp":1695828847829}],"authorship_tag":"ABX9TyNVmK1bpaLTbvFkiSvUNQSc"},"kernelspec":{"name":"python3","display_name":"Python 3"},"language_info":{"name":"python"}},"cells":[{"cell_type":"markdown","source":["# ПРАКТИЧЕСКОЕ ЗАДАНИЕ 1"],"metadata":{"id":"Bt7Qnt_Z71Jo"}},{"cell_type":"markdown","source":["Требуется решить три задачи:\n","\n","1. Пользуясь алгоритмом Кросс-Энтропии обучить агента решать задачу Taxi-v3 из Gym. Исследовать гиперпараметры алгоритма и выбрать лучшие.\n","\n","2. Реализовать алгоритм Кросс-Энтропии с двумя типами сглаживания,  указанными в лекции 1. При выбранных в пункте 1 гиперпараметров сравнить их результаты с результатами алгоритма без сглаживания.\n","\n","3. Реализовать модификацию алгоритма Кросс-Энтропии для стохастических сред, указанную в лекции 1. Сравнить ее результат с алгоритмами из пунктов 1 и 2."],"metadata":{"id":"vN77Q_T1liw-"}},{"cell_type":"markdown","source":["##Задача 1. CROSS ENTROPY METHOD"],"metadata":{"id":"Q5nDlxVa72jL"}},{"cell_type":"markdown","source":["Пользуясь алгоритмом Кросс-Энтропии обучить агента решать задачу Taxi-v3 из Gym. Исследовать гиперпараметры алгоритма и выбрать лучшие."],"metadata":{"id":"rPYq7_xc73go"}},{"cell_type":"code","source":["import gym\n","import numpy as np\n","import random\n","import time\n","\n","import matplotlib.pyplot as plt"],"metadata":{"id":"6mP3E9G_6PmN","executionInfo":{"status":"ok","timestamp":1696844844787,"user_tz":-180,"elapsed":1071,"user":{"displayName":"Irina Arcadieva","userId":"00917846547842133085"}}},"execution_count":1,"outputs":[]},{"cell_type":"code","source":["env = gym.make('Taxi-v3')"],"metadata":{"id":"ef1LQ387KnIp","executionInfo":{"status":"ok","timestamp":1696844852204,"user_tz":-180,"elapsed":487,"user":{"displayName":"Irina Arcadieva","userId":"00917846547842133085"}}},"execution_count":3,"outputs":[]},{"cell_type":"code","source":["print('states: ', env.observation_space)\n","print('actions: ', env.action_space)"],"metadata":{"id":"5rzs4Ts3GABy","colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"status":"ok","timestamp":1696844856331,"user_tz":-180,"elapsed":482,"user":{"displayName":"Irina Arcadieva","userId":"00917846547842133085"}},"outputId":"52ef4c39-07e8-4ef5-a408-b63827db730d"},"execution_count":4,"outputs":[{"output_type":"stream","name":"stdout","text":["states:  Discrete(500)\n","actions:  Discrete(6)\n"]}]},{"cell_type":"code","source":["def cross_entropy(env, iteration_n, trajectory_n, q_param, laplace, smooth):\n","    state_n = env.observation_space.n\n","    action_n = env.action_space.n\n","\n","    policy = np.ones((state_n, action_n)) / action_n\n","    max_reward = -10000\n","    max_policy = policy.copy()\n","    max_iter = 0\n","\n","    mean_total_rewards = []\n","\n","    for iteration in range(iteration_n):\n","\n","        #policy evaluation\n","        all_states, all_actions, all_rewards = [], [], []\n","        for k in range(trajectory_n):\n","            states, actions, total_reward = get_trajectory(env, policy)\n","            all_states.append(states)\n","            all_actions.append(actions)\n","            all_rewards.append(total_reward)\n","        mean_reward = np.mean(all_rewards)\n","        mean_total_rewards.append(mean_reward)\n","\n","        if mean_reward > max_reward:\n","            max_reward = mean_reward\n","            max_policy = policy.copy()\n","            max_iter = iteration\n","\n","        # print('iteration:', iteration,\n","        #       'mean total reward:', np.mean(all_rewards))\n","\n","        #policy improvement\n","        elite_states, elite_actions = select_elites(all_states, all_actions,\n","                                                    all_rewards, q_param)\n","        policy = update_policy(elite_states, elite_actions, policy,\n","                               laplace, smooth)\n","\n","    return mean_total_rewards, max_policy, max_reward, max_iter\n"],"metadata":{"id":"Cuq5jNx4IrdZ"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["def get_trajectory(env, policy, max_len=10000):\n","    action_n = env.action_space.n\n","\n","    states, actions = [], []\n","    total_reward = 0.0\n","\n","    state = env.reset()\n","\n","    for _ in range(max_len):\n","        action = np.random.choice(action_n, p=policy[state])\n","        new_state, reward, done, _ = env.step(action)\n","\n","        states.append(state)\n","        actions.append(action)\n","        total_reward += reward\n","\n","        state = new_state\n","        if done:\n","            break\n","\n","    return states, actions, total_reward"],"metadata":{"id":"JpNw52fgGzqR","executionInfo":{"status":"ok","timestamp":1696844867141,"user_tz":-180,"elapsed":477,"user":{"displayName":"Irina Arcadieva","userId":"00917846547842133085"}}},"execution_count":5,"outputs":[]},{"cell_type":"code","source":["def select_elites(all_states, all_actions, all_rewards, q_param):\n","    quantile = np.quantile(all_rewards, q_param)\n","    elite_states = []\n","    elite_actions = []\n","    for i in range(len(all_rewards)):\n","        if all_rewards[i] > quantile:\n","            elite_states.append(all_states[i])\n","            elite_actions.append(all_actions[i])\n","    return elite_states, elite_actions\n"],"metadata":{"id":"IDpsI4sWHG67"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["def update_policy(elite_states, elite_actions, policy, laplace, smooth):\n","    state_n = env.observation_space.n\n","    action_n = env.action_space.n\n","\n","    new_policy = np.zeros((state_n, action_n))\n","    for i in range(len(elite_states)):\n","        for state, action in zip(elite_states[i], elite_actions[i]):\n","            new_policy[state, action] += 1\n","\n","    for state in range(state_n):\n","        sum_state = np.sum(new_policy[state]) + laplace * action_n\n","        if sum_state > 0:\n","            new_policy[state] = (new_policy[state] + laplace) / sum_state\n","        else:\n","            new_policy[state] = policy[state].copy()\n","\n","    new_policy = smooth * new_policy + (1 - smooth) * policy.copy()\n","\n","    return new_policy\n"],"metadata":{"id":"rOhMut7cDRqr","executionInfo":{"status":"ok","timestamp":1696844873358,"user_tz":-180,"elapsed":520,"user":{"displayName":"Irina Arcadieva","userId":"00917846547842133085"}}},"execution_count":6,"outputs":[]},{"cell_type":"code","source":["# CROSS ENTROPY METHOD\n","\n","iteration_n = 50\n","trajectory_n = 5000\n","laplace = 0.0          # no laplace smoothing\n","smooth = 1.0           # no policy smoothing\n","\n","q_parameters = [0.9, 0.7, 0.5, 0.3, 0.1]\n","for q_param in q_parameters:\n","    mean_total_rewards, max_policy, max_reward, max_iter = \\\n","                        cross_entropy(env, iteration_n, trajectory_n,\n","                                      q_param, laplace, smooth)\n","    print('q =', q_param, 'max reward =', max_reward,\n","          'on iteration =', max_iter)\n","    plt.plot(mean_total_rewards, label='q='+str(q_param))\n","\n","plt.title('Cross Entropy Method with q_parameters')\n","plt.xlabel('iterations')\n","plt.ylabel('rewards')\n","plt.legend()\n","plt.show()\n"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":569},"id":"C71woNsrQWiX","executionInfo":{"status":"ok","timestamp":1696761529345,"user_tz":-180,"elapsed":4208148,"user":{"displayName":"Irina Arcadieva","userId":"00917846547842133085"}},"outputId":"e85e7de6-e435-43a6-ab00-0f3562ef1b87"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["q = 0.9 max reward =  1.566 on iteration = 29\n","q = 0.7 max reward =  7.778 on iteration = 23\n","q = 0.5 max reward =  7.953 on iteration = 44\n","q = 0.3 max reward =  7.954 on iteration = 47\n","q = 0.1 max reward =  -26.6024 on iteration = 49\n"]},{"output_type":"display_data","data":{"text/plain":["<Figure size 640x480 with 1 Axes>"],"image/png":"\n"},"metadata":{}}]},{"cell_type":"markdown","source":["Выводы:\n","1. Из закона больших чисел следует, что чем больше случайных траекторий будет построено, тем точнее будет вычислена оценка средней награды по выбранной политике. Поэтому зададим число траекторий величиной trajectory_n = 5000.\n","2. На выбранном количестве траекторий вполне достаточно 50 итераций метода для получения приемлевого результата, что видно из графика.\n","3. Исходя из проведенного эксперимента над различными значениями параметра $q$, в качестве оптимального значения (по соотношению: наибольшее значение награды, количество необходимых для ее получения итераций, разумный смысл) возьмем $q=0.5$. Это значение означает, что половина построенных на каждой итерации траекторий будет отнесена к элитным, по которым и будет обновляться политика.\n"],"metadata":{"id":"B9afYDKX3vcY"}},{"cell_type":"markdown","source":["## Задача 2. Применение сглаживания"],"metadata":{"id":"hnD-W_ZR7WYY"}},{"cell_type":"markdown","source":["Требуется реализовать алгоритм Кросс-Энтропии с двумя типами сглаживания,  указанными в лекции 1. При выбранных в пункте 1 значений гиперпараметров сравнить их результаты с результатами алгоритма без сглаживания."],"metadata":{"id":"ipLddH8ZmeEG"}},{"cell_type":"markdown","source":["### Задача 2.1. CROSS ENTROPY METHOD with Laplace Smoothing\n"],"metadata":{"id":"Ql_wJgoE32FI"}},{"cell_type":"markdown","source":["Для выбора значений параметра laplace_lambda для исследования его влияния на решение воспользуемся данным нам рекомендациям:\n","\n","1) laplace_lambda = 0:\n","\n","Сглаживание не происходит. Вероятности полностью основаны на эмпирических счетчиках из предложенных траекторий. Это может привести к нулевым вероятностям для пар состояние-действие, которые не были замечены, что может быть вредным, если данные разреженные или среда стохастическая.\n","\n","2) laplace_lambda = 0.5:\n","\n","Происходит умеренное сглаживание. Каждый счетчик пары состояние-действие увеличивается на 0.5 перед нормализацией. Это делает вероятности более гладкими и предотвращает нулевые вероятности, позволяя при этом эмпирическим данным значительно влиять на политику. Эта настройка может обеспечить баланс между исследованием (попытками неисследованных действий) и использованием (использованием изученного поведения).\n","\n","3) laplace_lambda = 1.0:\n","\n","Происходит классическое сглаживание Лапласа (добавление единицы). Каждый счетчик пары состояние-действие увеличивается на 1 перед нормализацией. Это может значительно сгладить вероятности, особенно когда эмпирические счетчики низки. Эта настройка склонна содействовать большему исследованию за счет возможного разбавления значимых закономерностей, изученных из данных.\n","\n","4) laplace_lambda > 1:\n","\n","Происходит чрезмерное сглаживание. С laplace_lambda больше 1, эффект сглаживания доминирует над эмпирическими счетчиками, особенно когда эти счетчики низки. Это может привести к политике, которая слишком равномерна и не адаптирована к данным, возможно, затрудняя способность агента изучать эффективные поведенческие стратегии. Чем выше laplace_lambda, тем больше политика стремится к равномерному распределению действий для каждого состояния.\n","Значение laplace_lambda следует выбирать в зависимости от конкретной задачи, доступного объема данных и желаемого компромисса между исследованием и использованием."],"metadata":{"id":"-PV2IsSwF3Sq"}},{"cell_type":"code","source":["# CROSS ENTROPY METHOD with Laplace Smoothing\n","\n","iteration_n = 50\n","trajectory_n = 5000\n","q_param = 0.5          # the best\n","smooth = 1.0           # no policy smoothing\n","\n","laplace_parameters = [1.0, 0.8, 0.5, 0.3, 0.1]\n","for laplace in laplace_parameters:\n","    mean_total_rewards, max_policy, max_reward, max_iter = \\\n","                        cross_entropy(env, iteration_n, trajectory_n,\n","                                      q_param, laplace, smooth)\n","    print('laplace =', laplace, 'max reward =', max_reward,\n","          'on iteration =', max_iter)\n","    plt.plot(mean_total_rewards, label='laplace='+str(laplace))\n","\n","plt.title('Cross Entropy Method with Laplace Smoothing')\n","plt.xlabel('iterations')\n","plt.ylabel('rewards')\n","plt.legend()\n","plt.show()\n"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":569},"id":"BQFSaMUtamZO","executionInfo":{"status":"ok","timestamp":1696765704373,"user_tz":-180,"elapsed":3916070,"user":{"displayName":"Irina Arcadieva","userId":"00917846547842133085"}},"outputId":"f31d4e45-d696-4f71-9d06-cf8caadf623e"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["laplace = 1.0 max reward = -3.3482 on iteration = 16\n","laplace = 0.8 max reward = -1.8376 on iteration = 14\n","laplace = 0.5 max reward = -0.1528 on iteration = 14\n","laplace = 0.3 max reward = 0.486 on iteration = 13\n","laplace = 0.1 max reward = 2.9268 on iteration = 14\n"]},{"output_type":"display_data","data":{"text/plain":["<Figure size 640x480 with 1 Axes>"],"image/png":"\n"},"metadata":{}}]},{"cell_type":"markdown","source":["Видим, что уменьшение значения параметра lambda_laplace приводит к увеличению значения награды. Попробуем еще снизить значение параметра, при этом огрничимся 20 итерациями."],"metadata":{"id":"rkiB2H5XvBlK"}},{"cell_type":"code","source":["# CROSS ENTROPY METHOD with Laplace Smoothing\n","\n","iteration_n = 20\n","trajectory_n = 5000\n","q_param = 0.5          # the best\n","smooth = 1.0           # no policy smoothing\n","\n","laplace_parameters = [0.05, 0.01, 0.005, 0.001]\n","for laplace in laplace_parameters:\n","    mean_total_rewards, max_policy, max_reward, max_iter = \\\n","                        cross_entropy(env, iteration_n, trajectory_n,\n","                                      q_param, laplace, smooth)\n","    print('laplace =', laplace, 'max reward =', max_reward,\n","          'on iteration =', max_iter)\n","    plt.plot(mean_total_rewards, label='laplace='+str(laplace))\n","\n","plt.title('Cross Entropy Method with Laplace Smoothing')\n","plt.xlabel('iterations')\n","plt.ylabel('rewards')\n","plt.legend()\n","plt.show()\n"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":549},"id":"tiDtKhtwFEpH","executionInfo":{"status":"ok","timestamp":1696767836876,"user_tz":-180,"elapsed":1908304,"user":{"displayName":"Irina Arcadieva","userId":"00917846547842133085"}},"outputId":"1d183e2b-77df-4557-aa27-72cd55324fce"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["laplace = 0.05 max reward = 3.2938 on iteration = 14\n","laplace = 0.01 max reward = 3.0096 on iteration = 13\n","laplace = 0.005 max reward = 3.9432 on iteration = 13\n","laplace = 0.001 max reward = 3.9324 on iteration = 13\n"]},{"output_type":"display_data","data":{"text/plain":["<Figure size 640x480 with 1 Axes>"],"image/png":"\n"},"metadata":{}}]},{"cell_type":"markdown","source":["Выводы:\n","1. Метод сглаживания Лапласса при выбранных значениях параметра не приводит к желаемому результату. Максимальное значение награды получается меньше, чем в методе без сглаживания.\n","2. Наилучшие значения параметра, приводящие к наибольшим значениям награды, определяются достаточно малыми величинами."],"metadata":{"id":"7u9SmZ_Rto4x"}},{"cell_type":"markdown","source":["### Задача 2.2. CROSS ENTROPY METHOD with Policy Smoothing\n"],"metadata":{"id":"ZvzYU6Is9U4V"}},{"cell_type":"code","source":["# CROSS ENTROPY METHOD with Policy Smoothing\n","\n","iteration_n = 50\n","trajectory_n = 5000\n","q_param = 0.5          # the best\n","laplace = 0.0          # no laplace smoothing\n","\n","smooth_parameters = [0.9, 0.8, 0.7, 0.6, 0.5]\n","for smooth in smooth_parameters:\n","    mean_total_rewards, max_policy, max_reward, max_iter = \\\n","                        cross_entropy(env, iteration_n, trajectory_n,\n","                                      q_param, laplace, smooth)\n","    print('smooth =', smooth, 'max reward = ', max_reward,\n","          'on iteration =', max_iter)\n","    plt.plot(mean_total_rewards, label='smooth='+str(smooth))\n","\n","plt.title('Cross Entropy Method with Policy Smoothing')\n","plt.xlabel('iterations')\n","plt.ylabel('rewards')\n","plt.legend()\n","plt.show()\n"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":569},"id":"18lLVkMzamka","executionInfo":{"status":"ok","timestamp":1696771503262,"user_tz":-180,"elapsed":3666425,"user":{"displayName":"Irina Arcadieva","userId":"00917846547842133085"}},"outputId":"853de400-443e-4106-8033-9f1da47ee681"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["smooth = 0.9 max reward =  7.9924 on iteration = 48\n","smooth = 0.8 max reward =  7.953 on iteration = 45\n","smooth = 0.7 max reward =  7.9162 on iteration = 37\n","smooth = 0.6 max reward =  7.9158 on iteration = 41\n","smooth = 0.5 max reward =  7.8736 on iteration = 48\n"]},{"output_type":"display_data","data":{"text/plain":["<Figure size 640x480 with 1 Axes>"],"image/png":"\n"},"metadata":{}}]},{"cell_type":"markdown","source":["Выводы:\n","1. При использовании политики сглаживания к методу кросс-энтропии видим, что уменьшение значения параметра сглаживания незначительно уменьшает максимальное значение награды.\n","2. Значение параметра сглаживания определяет вклад текущей политики по сравнению с предыдущей политикой в обновление политики на каждой итерации.\n","Значения, мешьшие либо равные 0.5 снижают значимость текущей политики, поэтому вряд ли будут допустимыми.\n","3. Значения параметра сглаживания в диапазоне от 0.6 до 0.9 дают хороший результат.\n"],"metadata":{"id":"ZosPV5wmmmmt"}},{"cell_type":"markdown","source":["## Задача 3. Применение стохастической среды"],"metadata":{"id":"iI3EHKpot2Je"}},{"cell_type":"markdown","source":["Реализовать модификацию алгоритма Кросс-Энтропии для стохастических сред, указанную в лекции 1. Сравнить результат с алгоритмами из пунктов 1 и 2."],"metadata":{"id":"JiszH9FLmjpD"}},{"cell_type":"markdown","source":["Рекомендации:\n","1. Сэмплим M пачек по K траекторий с использованием текущей политики\n","2. Для каждого M сэмпла считаем mean total reward\n","3. Выбираем все пачки траекторий, чей mean total reward попал в квантиль\n","4. Фиттим как в задаче 1 на этом наборе"],"metadata":{"id":"Re8W_SLZG4D0"}},{"cell_type":"code","source":["def cross_entropy_stochastic(env, iteration_n, batch_n, trajectory_n,\n","                             q_param, laplace, smooth):\n","    state_n = env.observation_space.n\n","    action_n = env.action_space.n\n","\n","    policy = np.ones((state_n, action_n)) / action_n\n","    max_reward = -10000\n","    max_policy = policy.copy()\n","    max_iter = 0\n","\n","    mean_total_rewards = []\n","\n","    for iteration in range(iteration_n):\n","\n","        #policy evaluation\n","        all_states, all_actions, all_rewards = [], [], []\n","        for m in range(batch_n):\n","            batch_states, batch_actions, batch_rewards = [], [], []\n","            for k in range(trajectory_n):\n","                states, actions, total_reward = get_trajectory(env, policy)\n","                batch_states.append(states)\n","                batch_actions.append(actions)\n","                batch_rewards.append(total_reward)\n","            batch_mean_reward = np.mean(batch_rewards)\n","            all_states.append(batch_states)\n","            all_actions.append(batch_actions)\n","            all_rewards.append(batch_mean_reward)\n","\n","        mean_reward = np.mean(all_rewards)\n","        mean_total_rewards.append(mean_reward)\n","\n","        if mean_reward > max_reward:\n","            max_reward = mean_reward\n","            max_policy = policy.copy()\n","            max_iter = iteration\n","\n","        #policy improvement\n","        elite_states, elite_actions = select_elites(all_states, all_actions,\n","                                                    all_rewards, q_param)\n","        policy = update_policy(elite_states, elite_actions, policy,\n","                               laplace, smooth)\n","\n","    return mean_total_rewards, max_policy, max_reward, max_iter\n"],"metadata":{"id":"pqfXz1yYG2p3","executionInfo":{"status":"ok","timestamp":1696846892807,"user_tz":-180,"elapsed":463,"user":{"displayName":"Irina Arcadieva","userId":"00917846547842133085"}}},"execution_count":14,"outputs":[]},{"cell_type":"code","source":["def select_elites(all_states, all_actions, all_rewards, q_param):\n","    quantile = np.quantile(all_rewards, q_param)\n","    elite_states = []\n","    elite_actions = []\n","    for i in range(len(all_rewards)):\n","        if all_rewards[i] > quantile:\n","            elite_states.extend(all_states[i])\n","            elite_actions.extend(all_actions[i])\n","    return elite_states, elite_actions\n"],"metadata":{"id":"Svt2lSEkkaKu","executionInfo":{"status":"ok","timestamp":1696846898129,"user_tz":-180,"elapsed":523,"user":{"displayName":"Irina Arcadieva","userId":"00917846547842133085"}}},"execution_count":15,"outputs":[]},{"cell_type":"code","source":["# CROSS ENTROPY METHOD with Stochastic Environment\n","\n","iteration_n = 100\n","q_param = 0.5\n","laplace = 0.0          # no laplace smoothing\n","smooth = 1.0           # no policy smoothing\n","\n","batch_parameters = [1000, 750, 500, 250]\n","\n","for batch_n in batch_parameters:\n","    trajectory_n = 5000 // batch_n\n","    mean_total_rewards, max_policy, max_reward, max_iter = \\\n","             cross_entropy_stochastic(env, iteration_n, batch_n, trajectory_n,\n","                                      q_param, laplace, smooth)\n","    print('batch_n =', batch_n, 'traject_n =', trajectory_n,\n","          'max reward =', max_reward, 'on iteration =', max_iter)\n","    plt.plot(mean_total_rewards, label='batch_n='+str(batch_n))\n","\n","plt.title('Cross Entropy Method with Stochastic')\n","plt.xlabel('iterations')\n","plt.ylabel('rewards')\n","plt.legend()\n","plt.show()\n"],"metadata":{"id":"-Jq8qD6pkbqr","colab":{"base_uri":"https://localhost:8080/","height":569},"executionInfo":{"status":"ok","timestamp":1696856799168,"user_tz":-180,"elapsed":5118558,"user":{"displayName":"Irina Arcadieva","userId":"00917846547842133085"}},"outputId":"78ad5fd0-397a-48e4-f07a-648fff528c34"},"execution_count":18,"outputs":[{"output_type":"stream","name":"stdout","text":["batch_n = 1000 traject_n = 5 max reward = 7.9768 on iteration = 97\n","batch_n = 750 traject_n = 6 max reward = 8.004666666666667 on iteration = 98\n","batch_n = 500 traject_n = 10 max reward = 7.911 on iteration = 89\n","batch_n = 250 traject_n = 20 max reward = 7.647399999999999 on iteration = 96\n"]},{"output_type":"display_data","data":{"text/plain":["<Figure size 640x480 with 1 Axes>"],"image/png":"\n"},"metadata":{}}]},{"cell_type":"markdown","source":["Выводы:\n","1. Исходя из проведенного эксперимента получаем, что лучше брать много пакетов с меньшим числом траекторий в каждом из них. Получаем большую награду за итоговую политику.\n","2. Однако полученный результат требует большего количества итераций по сравнению с задачей 1, в которой применяется детерминированная среда."],"metadata":{"id":"md6MUhY_jSoO"}},{"cell_type":"code","source":[],"metadata":{"id":"mjb7dhupkb18"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":[],"metadata":{"id":"FOo7CKyAd3M-"},"execution_count":null,"outputs":[]}]}